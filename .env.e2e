# Canonical env for `pnpm e2e` (local + CI). Loaded by playwright.config.ts with override.
# Do not put secrets here beyond test doubles (MinIO dev keys, CI JWT).

MONGODB_URI=mongodb://localhost:27017/travel-journal-test
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=travel-journal
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
JWT_SECRET=ci-test-secret
ADMIN_EMAIL=admin@localhost
SERVER_PORT=3101
