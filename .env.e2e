# Canonical env defaults for `pnpm e2e` (local + CI). Loaded by playwright.config.ts
# only when a key is not already set in the shell.
# Do not put secrets here beyond test doubles (MinIO dev keys, CI JWT).

# MONGODB_URI/S3_ENDPOINT/S3_BUCKET are computed dynamically by global setup when running
# locally with Testcontainers.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
JWT_SECRET=ci-test-secret
ADMIN_EMAIL=admin@localhost
SERVER_PORT=3101
